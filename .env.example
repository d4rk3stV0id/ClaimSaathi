# Supabase (optional): when both are set, the app enables sign-in and cloud sync for policies + claims.
# Get these from Project Settings → API in the Supabase dashboard. Use the anon key in the frontend only.
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# GEMINI_API_KEY: Optional; when set (with CLAIM_VISION not disabled), claim extraction uses Gemini on your PDFs/images before local OCR.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Optional second provider; used for claim vision extraction if Gemini fails or is unset.
OPENAI_API_KEY=""

# CLAIM_VISION: Set to 0 or false to force local-only claim extraction (no cloud multimodal step).
# CLAIM_VISION=

# Optional: first Gemini model for claims vision, then auto-fallback (default: Flash Lite first to reduce free-tier 429s).
# GEMINI_CLAIM_MODEL=
# OPENAI_CLAIM_MODEL=gpt-4.1-mini

# Optional: first model for Policy Saathi chat (default: same lite-first chain). Avoid forcing gemini-2.0-flash if you see quota errors.
# GEMINI_POLICY_CHAT_MODEL=

# Optional: first model for policy upload (no local OCR). Leave unset for lite-first fallback chain.
# GEMINI_POLICY_ANALYSIS_MODEL=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
